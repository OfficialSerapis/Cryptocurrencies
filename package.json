{
    "name": "selenium-electrum",
    "private": true,
    "version": "1.0.0",
    "workspaces": [
        "frontend",
        "backend"
    ],
    "scripts": {
        "start": "react-scripts start",
        "build": "react-scripts build",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs",
        "eject": "react-scripts eject",
        "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --testPathPattern=.*\\.unit\\.test\\.ts$",
        "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --testPathPattern=.*\\.integration\\.test\\.ts$",
        "test:frontend": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --testPathPattern=.*\\.frontend\\.test\\.(ts|tsx)$",
        "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch --config jest.config.cjs",
        "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --config jest.config.cjs",
        "test:all": "npm run test:unit && npm run test:integration && npm run test:frontend",
        "start:frontend": "cd frontend && npm run dev",
        "build:frontend": "cd frontend && npm run build",
        "start:backend": "cd backend && npm start",
        "test:backend": "cd backend && npm test",
        "test:contracts": "npx hardhat test",
        "deploy": "npx hardhat run scripts/deploy.js --network mainnet",
        "compile": "npx hardhat compile"
    },
    "description": "Dual-token cryptocurrency system featuring Selenium Coin and Electrum Coin",
    "main": "src/index.ts",
    "dependencies": {
        "@ethersproject/contracts": "^5.7.0",
        "@ethersproject/providers": "^5.7.2",
        "@openzeppelin/contracts": "^5.3.0",
        "@tanstack/react-query": "^5.0.0",
        "axios": "^1.6.0",
        "chart.js": "^4.4.0",
        "ethers": "^5.7.2",
        "glob": "^11.0.3",
        "react": "^18.3.1",
        "react-chartjs-2": "^5.2.0",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.21.3",
        "tailwindcss": "^3.4.0",
        "web3": "^1.10.0",
        "zod": "^3.22.0"
    },
    "devDependencies": {
        "@babel/core": "^7.24.0",
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/plugin-proposal-optional-chaining": "^7.21.0",
        "@babel/plugin-transform-logical-assignment-operators": "^7.23.3",
        "@babel/plugin-transform-modules-commonjs": "^7.23.3",
        "@babel/plugin-transform-nullish-coalescing-operator": "^7.23.4",
        "@babel/plugin-transform-numeric-separator": "^7.23.4",
        "@babel/plugin-transform-private-methods": "^7.23.3",
        "@babel/plugin-transform-private-property-in-object": "^7.23.4",
        "@babel/plugin-transform-runtime": "^7.24.0",
        "@babel/preset-env": "^7.24.0",
        "@babel/preset-react": "^7.23.3",
        "@babel/preset-typescript": "^7.23.3",
        "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
        "@nomicfoundation/hardhat-ethers": "^3.0.0",
        "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
        "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
        "@nomicfoundation/hardhat-toolbox": "^6.0.0",
        "@nomicfoundation/hardhat-verify": "^2.0.0",
        "@testing-library/jest-dom": "^6.4.2",
        "@testing-library/react": "^14.2.1",
        "@testing-library/user-event": "^14.5.2",
        "@typechain/ethers-v5": "^11.1.2",
        "@typechain/ethers-v6": "^0.3.1",
        "@typechain/hardhat": "^8.0.0",
        "@types/chai": "^4.2.0",
        "@types/jest": "^29.5.12",
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.11.5",
        "@types/react": "^18.2.48",
        "@types/react-dom": "^18.2.18",
        "@types/text-encoding": "^0.0.40",
        "babel-jest": "^29.7.0",
        "chai": "^5.2.0",
        "chai-as-promised": "^8.0.1",
        "chromedriver": "^138.0.0",
        "core-js": "^3.43.0",
        "cross-env": "^7.0.3",
        "dotenv": "^17.0.0",
        "glob": "^10.3.10",
        "hardhat": "^2.25.0",
        "hardhat-gas-reporter": "^2.3.0",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^30.0.2",
        "mocha": "^11.7.1",
        "prettier": "^3.2.4",
        "react-refresh": "^0.14.0",
        "selenium-webdriver": "^4.34.0",
        "solidity-coverage": "^0.8.16",
        "text-encoding": "^0.7.0",
        "ts-jest": "^29.4.0",
        "ts-mocha": "^11.1.0",
        "ts-node": "^10.9.2",
        "typechain": "^8.3.0",
        "typescript": "^5.8.3",
        "vite": "^5.4.18",
        "winston": "^3.17.0"
    },
    "engines": {
        "node": ">=16.0.0"
    },
    "hardhat": {
        "config": "./hardhat.config.cjs"
    },
    "directories": {
        "example": "examples",
        "test": "tests"
    },
    "keywords": [],
    "author": "",
    "license": "ISC"
}
